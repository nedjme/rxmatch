# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google AI (Gemini) — used for prescription extraction
# The API key is bundled into the desktop binary (never sent to a web server)
VITE_GOOGLE_AI_API_KEY=your-google-ai-key
VITE_GOOGLE_MODEL=gemini-1.5-flash
VITE_GOOGLE_ESCALATION_MODEL=gemini-1.5-pro

# Admin account — this email gets admin panel access
VITE_ADMIN_EMAIL=admin@votrelaboratoire.dz
